# Example environment file for CALM-SLA
# Copy this file to .env and update the values with your own credentials.

# ElectricityMaps API key for live carbon intensity polling
ELECTRICITYMAPS_API_KEY=your_electricitymaps_api_key_here

# WattTime API credentials for live carbon signal data
WATTTIME_USERNAME=your_watttime_username_here
WATTTIME_PASSWORD=your_watttime_password_here
WATTTIME_USER_EMAIL=your_watttime_email_here
WATTTIME_ORG=your_watttime_org_here

# Optional: override the WattTime API URL if needed
# WATTTIME_USING_API_URL=https://api2.watttime.org/v3/

# GCP configuration for real migration support
GCP_PROJECT_ID=your_gcp_project_id_here
# Use one of these to provide the path to your GCP service account credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
# or
GCP_CREDENTIALS_FILE=/path/to/your-service-account.json

# Optional: if you want to supply per-VM metadata via environment, you can do so
# through your own VM inventory setup rather than here.
# Example VM metadata fields required by gcp_migration.py:
# gcp_instance_name, gcp_source_zone, gcp_target_zone, gcp_target_instance_name
